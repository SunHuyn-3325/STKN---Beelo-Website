EN-NZ\" data-contrast=\"none\"\u003e\u003cspan data-ccp-parastyle=\"Normal (Web)\"\u003e\u003cstrong\u003e \u003c\/strong\u003eMade with cosmetic-grade, food-safe ingredients that are gentle on skin and kind to the planet.\u003c\/span\u003e\u003c\/span\u003e\u003cspan data-ccp-props='{\"134233117\":true,\"134233118\":true,\"201341983\":0,\"335559739\":0,\"335559740\":240}'\u003e \u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003e\u003cspan data-ccp-charstyle=\"Strong\"\u003eColourful mess, no stress:\u003c\/span\u003e\u003c\/strong\u003e\u003cspan style=\"font-size: 0.875rem;\" lang=\"EN-NZ\" data-contrast=\"none\"\u003e\u003cspan data-ccp-parastyle=\"Normal (Web)\"\u003e\u003cstrong\u003e \u003c\/strong\u003eWashes easily from hands and most non-porous surfaces with warm water and natural soap.\u003c\/span\u003e\u003c\/span\u003e\u003cspan style=\"font-size: 0.875rem;\" data-ccp-props='{\"134233117\":true,\"134233118\":true,\"201341983\":0,\"335559739\":0,\"335559740\":240}'\u003e \u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003e\u003cspan data-ccp-charstyle=\"Strong\"\u003eSix bright colours to explore:\u003c\/span\u003e\u003c\/strong\u003e\u003cspan style=\"font-size: 0.875rem;\" lang=\"EN-NZ\" data-contrast=\"none\"\u003e\u003cspan data-ccp-parastyle=\"Normal (Web)\"\u003e Includes blue, green, yellow, purple, \u003c\/span\u003e\u003cspan data-ccp-parastyle=\"Normal (Web)\"\u003ered\u003c\/span\u003e\u003cspan data-ccp-parastyle=\"Normal (Web)\"\u003e and orange – each packed in our signature beehive-shaped 60ml pots.\u003c\/span\u003e\u003c\/span\u003e\u003cspan style=\"font-size: 0.875rem;\" data-ccp-props='{\"134233117\":true,\"134233118\":true,\"201341983\":0,\"335559739\":0,\"335559740\":240}'\u003e \u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003e\u003cspan style=\"font-size: 0.875rem;\" data-ccp-props='{\"134233117\":true,\"134233118\":true,\"201341983\":0,\"335559739\":0,\"335559740\":240}'\u003eE\u003c\/span\u003e\u003cspan data-ccp-charstyle=\"Strong\"\u003eco-conscious and gift-ready:\u003c\/span\u003e\u003c\/strong\u003e\u003cspan style=\"font-size: 0.875rem;\" lang=\"EN-NZ\" data-contrast=\"none\"\u003e\u003cspan data-ccp-parastyle=\"Normal (Web)\"\u003e\u003cstrong\u003e \u003c\/strong\u003ePackaged in a cheerful, recyclable box with pots made from 100% recycled plastic.\u003c\/span\u003e\u003c\/span\u003e\u003cspan style=\"font-size: 0.875rem;\" data-ccp-props='{\"134233117\":true,\"134233118\":true,\"201341983\":0,\"335559739\":0,\"335559740\":240}'\u003e \u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003e\u003cspan style=\"font-size: 0.875rem;\" data-ccp-props='{\"134233117\":true,\"134233118\":true,\"201341983\":0,\"335559739\":0,\"335559740\":240}'\u003eDe\u003c\/span\u003e\u003cspan data-ccp-charstyle=\"Strong\"\u003esigned by parents, for parents:\u003c\/span\u003e\u003c\/strong\u003e\u003cspan style=\"font-size: 0.875rem;\" lang=\"EN-NZ\" data-contrast=\"none\"\u003e\u003cspan data-ccp-parastyle=\"Normal (Web)\"\u003e\u003cstrong\u003e \u003c\/strong\u003eAt Honeysticks, we believe in a better way to play – safe, sustainable, and full of wonder.\u003c\/span\u003e\u003c\/span\u003e\u003cspan style=\"font-size: 0.875rem;\" data-ccp-props='{\"134233117\":true,\"134233118\":true,\"201341983\":0,\"335559739\":0,\"335559740\":240}'\u003e \u003c\/span\u003e\u003cspan style=\"font-size: 0.875rem;\" data-ccp-props='{\"134233117\":true,\"134233118\":true,\"201341983\":0,\"335559739\":0,\"335559740\":240}'\u003e\u003c\/span\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003cdiv\u003e\n\u003cp\u003e\u003cem\u003e\u003cstrong\u003e\u003cspan lang=\"EN-NZ\" data-contrast=\"none\"\u003e\u003cspan data-ccp-parastyle-defn='{\"ObjectId\":\"b71b86aa-d72c-5c05-bc38-eb0d9113b743|1\",\"ClassId\":1073872969,\"Properties\":[469777841,\"Times New Roman\",469777842,\"Times New Roman\",469777843,\"Times New Roman\",469777844