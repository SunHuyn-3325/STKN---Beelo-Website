\n\u003c\/div\u003e\n\u003c\/div\u003e","brand":"Honeysticks UK","offers":[{"title":"Default Title","offer_id":57531702772093,"sku":"HCRJM16","price":19.95,"currency_code":"GBP","in_stock":false}],"thumbnail_url":"\/\/cdn.shopify.com\/s\/files\/1\/0553\/5465\/4896\/files\/CJ16.png?v=1765230533"}],"url":"https:\/\/honeysticks.co.uk\/collections\/featured-products.oembed","provider":"Honeysticks UK","version":"1.0","type":"link"}